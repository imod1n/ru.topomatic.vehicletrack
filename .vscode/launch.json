{
    "configurations": [
        {
            "name": "Launch Chrome",
            "request": "launch",
            "type": "chrome",
            "url": "https://360.topomatic.ru?extensionDevelopmentPath=http%3A%2F%2Flocalhost%3A9091",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "msedge",
            "name": "Топоматик 360 (браузер)",
            "request": "launch",
            "url": "https://360.topomatic.ru?extensionDevelopmentPath=http%3A%2F%2Flocalhost%3A9091"
        },
        {
            "type": "node",
            "name": "Топоматик 360 Desktop (отладка)",
            "request": "launch",
            "runtimeExecutable": "c:\\Program Files\\topomatic360\\topomatic360.exe",
            "runtimeArgs": [
                "--extensionDevelopmentPath=http%3A%2F%2Flocalhost%3A9091",
                "--remote-debugging-port=9222"
            ],
            "port": 9222,
            "timeout": 30000
        }
    ]
}
