{
  "name": "ru.topomatic.vehicletrack",
  "version": "1.0.0",
  "description": "Плагин расчёта траекторий движения ТС и коридоров движения для Топоматик 360",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "serve": "vite preview"
  },
  "albatros": {
    "displayName": "Коридор движения ТС",
    "description": "Расчёт траекторий движения транспортных средств (аналог AutoTURN)",
    "commands": [
      {
        "id": "vehicletrack:calculate",
        "label": "Рассчитать коридор движения ТС",
        "icon": "directions_car",
        "category": "Коридор движения"
      }
    ],
    "rules": [
      {
        "id": "vehicletrack:calculate",
        "label": "Коридор движения ТС",
        "description": "Расчёт траектории и коридора движения транспортного средства",
        "icon": "directions_car",
        "properties": [
          {
            "provider": "property:vehiclePreset",
            "label": "Тип ТС",
            "group": "Транспортное средство"
          },
          {
            "provider": "property:numericParam",
            "field": "customWheelbase",
            "label": "Колёсная база (м)",
            "group": "Параметры ТС"
          },
          {
            "provider": "property:numericParam",
            "field": "customTrackWidth",
            "label": "Ширина колеи (м)",
            "group": "Параметры ТС"
          },
          {
            "provider": "property:numericParam",
            "field": "customOverhangFront",
            "label": "Передний свес (м)",
            "group": "Параметры ТС"
          },
          {
            "provider": "property:numericParam",
            "field": "customOverhangRear",
            "label": "Задний свес (м)",
            "group": "Параметры ТС"
          },
          {
            "provider": "property:numericParam",
            "field": "customTurningRadius",
            "label": "Мин. радиус поворота (м)",
            "group": "Параметры ТС"
          }
        ]
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
