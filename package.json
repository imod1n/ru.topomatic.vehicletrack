{
  "name": "ru.topomatic.vehicletrack",
  "version": "1.0.0",
  "description": "Плагин расчёта траекторий движения ТС и коридоров движения для Топоматик 360",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.esm.js",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.vue"
  },
  "topomatic": {
    "pluginId": "ru.topomatic.vehicletrack",
    "displayName": "Коридор движения ТС",
    "version": "1.0.0",
    "minPlatformVersion": "1.0.0",
    "entry": "dist/index.js"
  },
  "dependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vue-tsc": "^2.0.0"
  },
  "keywords": ["topomatic", "albatros", "ifc", "bim", "autoturn", "vehicle"],
  "license": "MIT"
}
